# Copy this file to terraform.tfvars and fill in your values.

###############################################################################
# AWS / project basics
###############################################################################

# us-east-1 chosen for the booth: most AZ headroom, standard for OCP IPI demos.
# VPC is BYO and created in <region>{a,b,c}; if you change region, change
# the prereqs/terraform.tfvars region to match.
aws_region   = "us-east-1"
aws_profile  = null            # null = default credential chain
owner_email  = "austen@coder.com"

###############################################################################
# OpenShift cluster
###############################################################################

cluster_name             = "cluster"
base_domain              = "rh.coderdemo.io"   # YOUR public Route 53 zone
openshift_version        = "stable-4.21"
openshift_install_binary = "openshift-install" # path to 4.21+ binary
oc_binary                = "oc"
install_dir              = "./.cluster"

pull_secret_path  = "~/.openshift/pull-secret.json"
ssh_pubkey_path   = "~/.ssh/id_ed25519.pub"

# Compact 3-node converged cluster — control-plane nodes are also schedulable
# for workloads (compute.replicas: 0 in install-config.yaml). m6i.4xlarge
# gives ~13 vCPU usable per node after kube-control-plane + OS overhead;
# 3 nodes × 13 = 39 vCPU usable for everything except RHAIIS, which lives
# on the separate GPU node.
control_plane_count         = 3
control_plane_instance_type = "m6i.4xlarge"
worker_count                = 0          # converged — no dedicated worker pool
worker_instance_type        = "m6i.2xlarge"   # placeholder, unused when worker_count = 0

# GPU pool — always 1 node when the cluster is up. RHAIIS (vllm-cuda-rhel9)
# lands here exclusively via nodeSelector + nvidia.com/gpu resource request.
gpu_count          = 1
gpu_instance_type  = "g5.2xlarge"   # 1× A10G GPU (24 GiB VRAM), 8 vCPU, 32 GiB RAM
gpu_zone_index     = 0              # us-east-1a

# Single-Node OpenShift (cheapest "demo" — no HA story, no GPU):
# control_plane_count         = 1
# control_plane_instance_type = "m6i.8xlarge"
# worker_count                = 0
# gpu_count                   = 0

###############################################################################
# Coder
###############################################################################

# Latest tagged RC for full Coder Agents EA functionality.
# v2.33.0-rc.3 (commit 3362b5ae, Apr 22 2026) is the latest tagged candidate.
# RC tags live directly on `main` under the new release process — bump only
# when a newer tagged rc.N exists, not on every main HEAD movement.
coder_chart_version = "2.33.0-rc.3"
coder_image_tag     = "v2.33.0-rc.3"
coder_subdomain     = "coder"
coder_oidc_provider_url = ""     # leave empty to use built-in user/pass for the booth
