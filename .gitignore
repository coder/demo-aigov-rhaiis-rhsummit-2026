# Terraform
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl
*.tfplan
crash.log
override.tf
override.tf.json

# Secrets / credentials
# NOTE: with ESO + AWS Secrets Manager, no actual secret values land in Git —
# only ExternalSecret manifests that reference AWS SM. Don't re-add the
# overly-broad `*-secret.yaml` pattern; it caught legit ExternalSecret
# manifests like manifests/rhaiis/external-secret-pull-secret.yaml.
*.pem
*.key
.env
.env.*
!.env.example
secrets-data.yaml
secret-data.yaml

